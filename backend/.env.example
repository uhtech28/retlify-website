# ═══════════════════════════════════════════════════════════════════
#  RETLIFY v3 — Environment Variables
#  Copy this file to .env and fill in real values.
#  ⚠️  NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/retlify

# JWT
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX
JWT_EMAIL_SECRET=REPLACE_WITH_ANOTHER_HEX
JWT_RESET_SECRET=REPLACE_WITH_YET_ANOTHER_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=REPLACE_WITH_32_BYTE_HEX

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=retlifyy@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
TO_EMAIL=retlifyy@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twilio OTP (optional — console logs in dev if omitted)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# URLs
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5000

# AI — Text generation (get FREE key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI — Image generation
# v3: Pollinations AI used — NO KEY REQUIRED. 100% free.
# HUGGINGFACE_API_KEY  --> REMOVED (deprecated)
# REPLICATE_API_TOKEN  --> REMOVED (requires payment)
